enum Name {
	matheus
	jorge
	teste
}

table User {
	id String @id @default(snowflake())
	# name Name @default(matheus)

	name String @default("Anonimo")
	age Integer? @default(10)
	
	reference String
	
	isAdmin Boolean @default(false)
}